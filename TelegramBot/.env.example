# Скопируйте в .env и заполните. .env в .gitignore — в репозиторий не попадёт.

# Токен бота от @BotFather (Telegram -> @BotFather -> /newbot)
TELEGRAM_BOT_TOKEN=

# Твой числовой Telegram user ID — единственный, кому бот будет отвечать.
# Узнать: написать @userinfobot в Telegram, он пришлёт ID в ответ.
ALLOWED_USER_ID=

# Путь к бинарнику claude (по умолчанию берётся из PATH)
CLAUDE_BIN=claude

# Изолированная рабочая директория бота — НЕ домашняя папка с ключами/конфигами.
# Сюда складываются входящие файлы от пользователя и файл сессий.
# 03-telegram-bot-setup.sh создаёт её сам и подставляет реальный путь.
WORK_DIR=/home/USER/telegram-bot-data

# Файл лога вопросов/ответов
LOG_FILE=/home/USER/telegram-bot-data/bot.log

# Таймаут одного запроса к Claude Code, мс (3 минуты по умолчанию)
REQUEST_TIMEOUT_MS=180000

# Порог свободного места на диске, при котором бот предупреждает и
# отказывается принимать файлы, МБ
MIN_FREE_SPACE_MB=1024

# Срок хранения временных файлов в WORK_DIR/incoming перед авто-чисткой, часы
TEMP_FILE_TTL_HOURS=72
